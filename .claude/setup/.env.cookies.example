# Agent-Reach Cookie 凭据模板
# 复制此文件为 .env.cookies 并填入实际值
# WARNING: .env.cookies 已在 .gitignore 中，不会提交到仓库

# Groq API Key（用于小宇宙播客字幕转录）
# 获取: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Twitter/X Auth Token（从浏览器 cookie 中获取）
TWITTER_AUTH_TOKEN=your_twitter_auth_token_here

# Twitter/X CSRF Token（从浏览器 cookie 中获取）
TWITTER_CT0=your_twitter_ct0_here
